{
  "manifest_version": 3,
  "name": "Cricket Live Commentary",
  "version": "1.0",
  "description": "Live AI cricket commentary from your browser screen",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cricket Commentary"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
